<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:paddingHorizontal="16dp">
        <ImageView
            android:id="@+id/btnBackWarrantyDetail"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:padding="6dp"
            android:src="@drawable/ic_back"
            app:tint="#3F51B5"
            android:contentDescription="Quay lại" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Chi tiết Bảo hành"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Thông tin chung -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tvDetailWarrantyOrderId"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Mã đơn hàng: #KRKYOFG"
                            android:textColor="#212121"
                            android:textStyle="bold" />
                        <ImageView
                            android:id="@+id/btnCopyOrderId"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_copy"
                            app:tint="#757575"
                            android:padding="2dp"
                            android:contentDescription="Sao chép mã đơn" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvDetailWarrantyUser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Khách hàng: user@gmail.com"
                        android:textColor="#757575" />
                    <TextView
                        android:id="@+id/tvDetailWarrantyStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_role_chip"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="Trạng thái: ĐANG CHỜ"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAdminViewWarrantyCard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Xem thẻ bảo hành >"
                        android:textColor="#3F51B5"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lỗi và Mô tả -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhóm lỗi:"
                        android:textColor="#212121"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDetailWarrantyError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="#E8EAF6"
                        android:padding="8dp"
                        android:text="Lỗi Nguồn/Khởi động"
                        android:textColor="#3F51B5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Mô tả tình trạng:"
                        android:textColor="#212121"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDetailWarrantyDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Mô tả chi tiết lỗi của khách hàng..."
                        android:textColor="#616161" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bằng chứng hình ảnh -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Hình ảnh bằng chứng:"
                android:textColor="#212121"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutWarrantyEvidenceImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/layoutAdminWarrantyActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRejectWarranty"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/rounded_edittext"
            android:text="TỪ CHỐI"
            android:textColor="#F44336"
            android:textSize="12sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnProcessWarranty"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1.2"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_sky_blue_gradient"
            android:text="TIẾP NHẬN"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCompleteWarranty"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_sky_blue_gradient"
            android:text="ĐÃ XONG"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
