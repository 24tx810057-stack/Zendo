<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="4dp">
        <ImageView
            android:id="@+id/btnBackWarranty"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:tint="#2196F3" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Yêu cầu Bảo hành/Sửa chữa"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tóm tắt Sản phẩm -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="12dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivWarrantyProduct"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo_zendo"
                    app:shapeAppearanceOverlay="@style/RoundedImage"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvWarrantyProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tên sản phẩm"
                        android:textColor="#212121"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                    <TextView
                        android:id="@+id/tvWarrantyExpiryInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Hạn bảo hành: 01/01/2026"
                        android:textColor="#2E7D32"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Loại lỗi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhóm lỗi gặp phải *"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <Spinner
                android:id="@+id/spWarrantyErrorType"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_border_gray_light"
                android:layout_marginBottom="16dp"/>

            <!-- Mô tả lỗi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mô tả chi tiết tình trạng *"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etWarrantyDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="4"
                android:gravity="top"
                android:padding="12dp"
                android:background="@drawable/bg_border_gray_light"
                android:hint="Ví dụ: Máy hay bị sập nguồn đột ngột khi đang sử dụng, màn hình có hiện tượng nhấp nháy..."
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Hình ảnh -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hình ảnh minh chứng lỗi (Tối đa 3) *"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RelativeLayout
                    android:id="@+id/btnPickWarrantyImages"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_border_gray_light">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_centerInParent="true"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#2196F3"/>
                </RelativeLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvWarrantyImages"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginStart="8dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Lưu ý: Sau khi gửi yêu cầu, trung tâm bảo hành Zendo sẽ liên hệ với bạn qua SĐT để hướng dẫn gửi máy về trung tâm gần nhất."
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:fontStyle="italic" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSubmitWarranty"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_sky_blue_gradient"
        android:text="GỬI YÊU CẦU BẢO HÀNH"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>
