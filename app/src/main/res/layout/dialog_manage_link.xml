<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_modern"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvManageLinkTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Thông tin liên kết"
        android:textColor="@color/slate_900"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tvManageLinkLabel1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên ngân hàng"
            android:textColor="@color/slate_500"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/tvManageLinkVal1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MB Bank"
            android:textColor="@color/slate_900"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvManageLinkLabel2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số tài khoản"
            android:textColor="@color/slate_500"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/tvManageLinkVal2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1234 5678 9012"
            android:textColor="@color/slate_900"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvManageLinkLabel3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chủ tài khoản"
            android:textColor="@color/slate_500"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/tvManageLinkVal3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NGUYEN VAN A"
            android:textColor="@color/slate_900"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnUnlink"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_border_gray_light"
        android:text="HỦY LIÊN KẾT"
        android:textColor="@color/rose_600"
        android:textSize="14sp"
        android:textStyle="bold" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCloseManage"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:text="ĐÓNG"
        android:textColor="@color/slate_500"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>