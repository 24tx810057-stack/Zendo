<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbarAddAddress"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBackAddAddress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:tint="#2196F3" />

        <TextView
            android:id="@+id/tvTitleAddAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Địa chỉ mới"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnSaveAddress"
        android:layout_below="@id/toolbarAddAddress"
        android:background="#F8F9FA">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:text="Thông tin địa chỉ"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Contact section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Họ và tên"
                        android:textSize="15sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Số điện thoại"
                        android:inputType="phone"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>


            <!-- Address section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:paddingHorizontal="16dp">
                    <EditText
                        android:id="@+id/etArea"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toStartOf="@+id/ivArrow"
                        android:background="@null"
                        android:hint="Tỉnh/Thành phố, Quận/Huyện..."
                        android:textSize="15sp"
                        android:focusable="false"
                        android:clickable="true" />
                    <ImageView
                        android:id="@+id/ivArrow"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#BDBDBD"/>
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="54dp"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <EditText
                        android:id="@+id/etDetailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="54dp"
                        android:background="@null"
                        android:hint="Số nhà, tên đường..."
                        android:textSize="15sp"
                        android:paddingVertical="8dp" />
                </LinearLayout>
            </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:text="Cài đặt"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Settings section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Loại địa chỉ" android:textColor="#212121" android:textSize="15sp" />
                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleGroupType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">
                        <Button
                            android:id="@+id/btnTypeOffice"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Văn Phòng"
                            android:textSize="12sp"
                            android:paddingHorizontal="12dp"
                            app:strokeColor="#E0E0E0"
                            android:textColor="#757575" />
                        <Button
                            android:id="@+id/btnTypeHome"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Nhà Riêng"
                            android:textSize="12sp"
                            android:paddingHorizontal="12dp"
                            app:strokeColor="#E0E0E0"
                            android:textColor="#757575" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#F0F0F0" android:layout_marginHorizontal="16dp"/>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="64dp" android:paddingHorizontal="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="Đặt làm địa chỉ mặc định" android:textColor="#212121" android:textSize="15sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swDefault"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        app:thumbTint="@color/blue_main"
                        app:trackTint="#B3E5FC" />
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSaveAddress"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:background="#E0E0E0"
        android:text="HOÀN THÀNH"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:elevation="0dp" />

</RelativeLayout>
