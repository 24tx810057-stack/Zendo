<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:padding="16dp">

    <RadioButton
        android:id="@+id/rbSelectAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:buttonTint="@color/blue_main"
        android:clickable="false"
        android:focusable="false"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/llAddressInfo" />

    <LinearLayout
        android:id="@+id/llAddressInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toStartOf="@+id/tvEditAddress"
        app:layout_constraintStart_toEndOf="@+id/rbSelectAddress"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/llHeaderInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Họ tên"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="8dp"
                android:background="#BDBDBD" />

            <TextView
                android:id="@+id/tvItemPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SĐT"
                android:textColor="#757575"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvItemDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Số nhà, tên đường"
            android:textColor="#424242"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvItemArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xã/Phường, Quận/Huyện, Tỉnh/Thành"
            android:textColor="#424242"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDefaultBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_circle_red_badge"
                android:backgroundTint="#E3F2FD"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Mặc định"
                android:textColor="@color/blue_main"
                android:textSize="10sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvPickupBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_border_gray_light"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Địa chỉ lấy hàng"
                android:textColor="#757575"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvEditAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="Sửa"
        android:textColor="@color/blue_main"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#F0F0F0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llAddressInfo" />

</androidx.constraintlayout.widget.ConstraintLayout>
