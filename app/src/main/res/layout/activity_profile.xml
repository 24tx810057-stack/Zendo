<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavProfile"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Header Profile Modern with bg.png -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg"
                android:paddingHorizontal="20dp"
                android:paddingTop="50dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/btnSetting"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_settings_gear"
                        app:tint="#FFFFFF" />

                    <!-- Nút Thông báo -->
                    <RelativeLayout
                        android:id="@+id/btnNotificationProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:id="@+id/ivNotificationIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_notifications"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:id="@+id/tvNotifBadgeProfile"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_alignTop="@id/ivNotificationIcon"
                            android:layout_alignEnd="@id/ivNotificationIcon"
                            android:layout_marginTop="-2dp"
                            android:layout_marginEnd="-2dp"
                            android:background="@drawable/bg_circle_red_badge"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/layoutCartProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/btnCartProfile"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_cart_logo"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:id="@+id/tvCartBadge"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_alignTop="@id/btnCartProfile"
                            android:layout_alignEnd="@id/btnCartProfile"
                            android:layout_marginTop="-2dp"
                            android:layout_marginEnd="-2dp"
                            android:background="@drawable/bg_circle_red_badge"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_person"
                        android:scaleType="centerCrop"
                        android:background="@color/white"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="#4DFFFFFF"
                        app:strokeWidth="2dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User Name"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvProfileRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_role_chip"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="2dp"
                            android:text="Thành viên"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- Main Content Container Modern -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-25dp"
                android:background="@drawable/bg_white_top_round"
                android:orientation="vertical"
                android:padding="20dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- SECTION: USER MENU -->
                <LinearLayout
                    android:id="@+id/layoutUserMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:visibility="gone">
                    <RelativeLayout
                        android:id="@+id/btnOrderHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:paddingBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đơn mua"
                            android:textStyle="bold"
                            android:textColor="#212121"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Xem lịch sử >"
                            android:textSize="12sp"
                            android:textColor="#757575"/>
                    </RelativeLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="10dp"
                        android:weightSum="4"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <RelativeLayout android:id="@+id/btnStatusPending" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false" android:clipToPadding="false">
                            <ImageView android:id="@+id/iv1" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_edit" app:tint="#424242"/>
                            <TextView android:id="@+id/badgePending" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="18dp" android:minHeight="18dp" android:layout_alignEnd="@id/iv1" android:layout_alignTop="@id/iv1" android:layout_marginTop="-8dp" android:layout_marginEnd="-8dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" android:elevation="4dp" android:padding="2dp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv1" android:text="Chờ xác nhận" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusPickup" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false" android:clipToPadding="false">
                            <ImageView android:id="@+id/iv2" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_map" app:tint="#424242"/>
                            <TextView android:id="@+id/badgePickup" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="18dp" android:minHeight="18dp" android:layout_alignEnd="@id/iv2" android:layout_alignTop="@id/iv2" android:layout_marginTop="-8dp" android:layout_marginEnd="-8dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" android:elevation="4dp" android:padding="2dp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv2" android:text="Chờ lấy hàng" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusShipping" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false" android:clipToPadding="false">
                            <ImageView android:id="@+id/iv3" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_email" app:tint="#424242"/>
                            <TextView android:id="@+id/badgeShipping" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="18dp" android:minHeight="18dp" android:layout_alignEnd="@id/iv3" android:layout_alignTop="@id/iv3" android:layout_marginTop="-8dp" android:layout_marginEnd="-8dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" android:elevation="4dp" android:padding="2dp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv3" android:text="Đang giao" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusReview" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false" android:clipToPadding="false">
                            <ImageView android:id="@+id/iv4" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/btn_star_big_on" app:tint="#424242"/>
                            <TextView android:id="@+id/badgeReview" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="18dp" android:minHeight="18dp" android:layout_alignEnd="@id/iv4" android:layout_alignTop="@id/iv4" android:layout_marginTop="-8dp" android:layout_marginEnd="-8dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" android:elevation="4dp" android:padding="2dp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv4" android:text="Đánh giá" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- SECTION: ADMIN SHOP CONTROL MODERN -->
                <LinearLayout
                    android:id="@+id/layoutAdminMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bảng điều khiển của Shop"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- MODERN REVENUE BANNER -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnRevenueStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_sky_blue_gradient"
                            android:orientation="vertical"
                            android:padding="24dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Doanh thu tháng này"
                                android:textColor="#B3FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="normal" />
                            <TextView
                                android:id="@+id/tvTotalRevenue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="0đ"
                                android:textColor="#FFFFFF"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:id="@+id/tvCompletedOrdersLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Đơn hàng thành công"
                                        android:textColor="#B3FFFFFF"
                                        android:textSize="12sp" />
                                    <TextView
                                        android:id="@+id/tvCompletedOrders"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 đơn"
                                        android:textColor="#FFFFFF"
                                        android:textSize="15sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#FFFFFF" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- MODERN GRID 2x2 CỦA ADMIN -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignMargins"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <!-- Đơn hàng -->
                        <RelativeLayout
                            android:id="@+id/btnAdminOrders"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_tile_item">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dash_orders" app:tint="@color/white"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Đơn hàng" android:textStyle="bold" android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tvAdminOrderBadge"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="10dp"
                                android:background="@drawable/bg_circle_red_badge"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:visibility="gone"/>
                        </RelativeLayout>

                        <!-- Sản phẩm -->
                        <RelativeLayout
                            android:id="@+id/btnAdminProducts"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_tile_item">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dash_products" app:tint="?attr/colorOnSurfaceVariant"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Sản phẩm" android:textStyle="bold" android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Khuyến mãi -->
                        <RelativeLayout
                            android:id="@+id/btnAdminVouchers"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_tile_item">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dash_vouchers" app:tint="?attr/colorOnSurfaceVariant"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Khuyến mãi" android:textStyle="bold" android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Đánh giá -->
                        <RelativeLayout
                            android:id="@+id/btnAdminReviews"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_tile_item">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dash_reviews" app:tint="?attr/colorOnSurfaceVariant"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Đánh giá" android:textStyle="bold" android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tvAdminReviewBadge"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="10dp"
                                android:background="@drawable/bg_circle_red_badge"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:visibility="gone" />
                        </RelativeLayout>

                        <!-- Khiếu nại -->
                        <RelativeLayout
                            android:id="@+id/btnAdminReturnRequests"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_tile_item">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dash_complaints" app:tint="@color/rose_600"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Khiếu nại" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/slate_700"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tvReturnBadge"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="10dp"
                                android:background="@drawable/bg_circle_red_badge"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:visibility="gone"/>
                        </RelativeLayout>

                        <!-- Bảo hành -->
                        <RelativeLayout
                            android:id="@+id/btnAdminWarrantyRequests"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_tile_item">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dash_warranty" app:tint="?attr/colorOnSurfaceVariant"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Bảo hành" android:textStyle="bold" android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tvWarrantyBadge"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="10dp"
                                android:background="@drawable/bg_circle_red_badge"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:visibility="gone"/>
                        </RelativeLayout>

                        <!-- Thanh toán -->
                        <RelativeLayout
                            android:id="@+id/btnAdminPaymentSettings"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_tile_item">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dash_payment" app:tint="@color/emerald_600"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Thanh toán" android:textStyle="bold" android:textSize="13sp" android:textColor="@color/slate_700"/>
                            </LinearLayout>
                        </RelativeLayout>

                        <!-- Ngành hàng -->
                        <RelativeLayout
                            android:id="@+id/btnAdminAttributes"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_tile_item">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dash_categories" app:tint="?attr/colorOnSurfaceVariant"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Ngành hàng" android:textStyle="bold" android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                            </LinearLayout>
                        </RelativeLayout>

                    </GridLayout>
                </LinearLayout>

                <View android:id="@+id/dividerWallet" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="?attr/colorOutline" />

                <LinearLayout
                    android:id="@+id/sectionWallet"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_zendopay" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Ví ZendoPay" android:textColor="?attr/colorOnSurface" android:textSize="14sp" />
                    <TextView android:id="@+id/tvProfileWalletBalance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="8dp" android:text="0đ" android:textColor="@color/blue_modern_primary" android:textSize="13sp" android:textStyle="bold" />
                    <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_arrow_right" app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View android:id="@+id/dividerFavorite" android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" />

                <LinearLayout
                    android:id="@+id/sectionFavorite"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_heart_filled" app:tint="@color/pink_heart" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Sản phẩm yêu thích" android:textColor="?attr/colorOnSurface" android:textSize="14sp" />
                    <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_arrow_right" app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" />

                <LinearLayout
                    android:id="@+id/sectionChat"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/stat_notify_chat" app:tint="@color/blue_modern_primary" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Chăm sóc khách hàng" android:textColor="?attr/colorOnSurface" android:textSize="14sp" />
                    <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_arrow_right" app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" />

                <LinearLayout
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_lock_idle_lock" app:tint="?attr/colorOnSurface" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Đổi mật khẩu" android:textColor="?attr/colorOnSurface" android:textSize="14sp" />
                    <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_arrow_right" app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutline" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="30dp"
                    android:background="@drawable/bg_revenue_modern"
                    android:text="ĐĂNG XUẤT"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:elevation="0dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:paddingBottom="40dp"
                android:background="#F5F5F5"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="16dp" android:text="CÓ THỂ BẠN SẼ THÍCH" android:textColor="#01579B" android:textStyle="bold" />
                <com.zendo.apps.ui.NonScrollGridView
                    android:id="@+id/gvSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:numColumns="2"
                    android:paddingHorizontal="10dp"
                    android:paddingBottom="10dp"
                    android:horizontalSpacing="10dp"
                    android:verticalSpacing="10dp"
                    android:stretchMode="columnWidth" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavProfile"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:elevation="8dp"
        app:itemIconSize="24dp"
        app:itemPaddingTop="8dp"
        app:itemPaddingBottom="10dp"
        app:itemIconTint="@color/selector_nav_color"
        app:itemTextColor="@color/selector_nav_color"
        app:itemTextAppearanceActive="@style/BottomNavText"
        app:itemTextAppearanceInactive="@style/BottomNavText"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:itemActiveIndicatorStyle="@null" />
</RelativeLayout>

