<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavProfile"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Header Profile -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg"
                android:paddingHorizontal="16dp"
                android:paddingTop="60dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/btnSetting"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginEnd="15dp"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="#FFFFFF" />

                    <!-- Nút Thông báo (Chuông) -->
                    <RelativeLayout
                        android:id="@+id/btnNotificationProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="15dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_notifications"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:id="@+id/tvNotifBadgeProfile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="18dp"
                            android:minHeight="18dp"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="-8dp"
                            android:layout_marginEnd="-8dp"
                            android:background="@drawable/bg_circle_red_badge"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:padding="2dp"
                            android:elevation="4dp"
                            android:visibility="gone" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/layoutCartProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageView
                            android:id="@+id/btnCartProfile"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_cart_logo"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:id="@+id/tvCartBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="18dp"
                            android:minHeight="18dp"
                            android:layout_alignTop="@id/btnCartProfile"
                            android:layout_alignEnd="@id/btnCartProfile"
                            android:layout_marginTop="-8dp"
                            android:layout_marginEnd="-8dp"
                            android:background="@drawable/bg_circle_red_badge"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:padding="2dp"
                            android:elevation="4dp"
                            android:visibility="gone" />
                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginBottom="50dp"
                    android:gravity="center_vertical">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/ic_person"
                        android:scaleType="centerCrop"
                        android:background="#FFFFFF"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="#FFFFFF"
                        app:strokeWidth="2dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User Name"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvProfileRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_role_chip"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="2dp"
                            android:text="Thành viên"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- Main Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-30dp"
                android:background="@drawable/bg_white_top_round"
                android:orientation="vertical"
                android:padding="16dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- SECTION: USER MENU -->
                <LinearLayout
                    android:id="@+id/layoutUserMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:visibility="gone">
                    <RelativeLayout
                        android:id="@+id/btnOrderHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:paddingBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đơn mua"
                            android:textStyle="bold"
                            android:textColor="#212121"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Xem lịch sử >"
                            android:textSize="12sp"
                            android:textColor="#757575"/>
                    </RelativeLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="10dp"
                        android:weightSum="4"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <RelativeLayout android:id="@+id/btnStatusPending" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false" android:clipToPadding="false">
                            <ImageView android:id="@+id/iv1" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_edit" app:tint="#424242"/>
                            <TextView android:id="@+id/badgePending" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="18dp" android:minHeight="18dp" android:layout_alignEnd="@id/iv1" android:layout_alignTop="@id/iv1" android:layout_marginTop="-8dp" android:layout_marginEnd="-8dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" android:elevation="4dp" android:padding="2dp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv1" android:text="Chờ xác nhận" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusPickup" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false" android:clipToPadding="false">
                            <ImageView android:id="@+id/iv2" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_map" app:tint="#424242"/>
                            <TextView android:id="@+id/badgePickup" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="18dp" android:minHeight="18dp" android:layout_alignEnd="@id/iv2" android:layout_alignTop="@id/iv2" android:layout_marginTop="-8dp" android:layout_marginEnd="-8dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" android:elevation="4dp" android:padding="2dp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv2" android:text="Chờ lấy hàng" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusShipping" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false" android:clipToPadding="false">
                            <ImageView android:id="@+id/iv3" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_email" app:tint="#424242"/>
                            <TextView android:id="@+id/badgeShipping" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="18dp" android:minHeight="18dp" android:layout_alignEnd="@id/iv3" android:layout_alignTop="@id/iv3" android:layout_marginTop="-8dp" android:layout_marginEnd="-8dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" android:elevation="4dp" android:padding="2dp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv3" android:text="Đang giao" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusReview" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false" android:clipToPadding="false">
                            <ImageView android:id="@+id/iv4" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/btn_star_big_on" app:tint="#424242"/>
                            <TextView android:id="@+id/badgeReview" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="18dp" android:minHeight="18dp" android:layout_alignEnd="@id/iv4" android:layout_alignTop="@id/iv4" android:layout_marginTop="-8dp" android:layout_marginEnd="-8dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="9sp" android:textStyle="bold" android:elevation="4dp" android:padding="2dp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv4" android:text="Đánh giá" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- SECTION: ADMIN SHOP CONTROL -->
                <LinearLayout
                    android:id="@+id/layoutAdminMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bảng điều khiển của Shop"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- BANNER DOANH THU -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnRevenueStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="0dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_sky_blue_gradient"
                            android:padding="20dp">
                            <ImageView
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="-20dp"
                                android:alpha="0.15"
                                android:src="@android:drawable/ic_menu_report_image"
                                app:tint="#FFFFFF" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Doanh thu tháng này"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/tvTotalRevenue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="0đ"
                                    android:textColor="#FFFFFF"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:layout_marginVertical="12dp"
                                    android:background="#33FFFFFF" />
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">
                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Đơn hoàn thành"
                                            android:textColor="#CCFFFFFF"
                                            android:textSize="12sp" />
                                        <TextView
                                            android:id="@+id/tvCompletedOrders"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0 đơn"
                                            android:textColor="#FFFFFF"
                                            android:textSize="14sp"
                                            android:textStyle="bold" />
                                    </LinearLayout>
                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/ic_arrow_right"
                                        app:tint="#FFFFFF" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- GRID 2x2 CỦA ADMIN -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:alignmentMode="alignMargins"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminOrders"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:clipChildren="false" android:clipToPadding="false">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#01579B"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Đơn hàng" android:textStyle="bold" android:textSize="13sp"/>
                                </LinearLayout>
                                <TextView
                                    android:id="@+id/tvAdminOrderBadge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:minWidth="18dp"
                                    android:minHeight="18dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_margin="8dp"
                                    android:background="@drawable/bg_circle_red_badge"
                                    android:gravity="center"
                                    android:textColor="#FFFFFF"
                                    android:textSize="9sp"
                                    android:textStyle="bold"
                                    android:elevation="4dp"
                                    android:padding="2dp"
                                    android:visibility="gone"/>
                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminProducts"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_input_add" app:tint="#FF9800"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Sản phẩm" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminVouchers"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" app:tint="#9C27B0"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Khuyến mãi" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminReviews"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/stat_notify_chat" app:tint="#4CAF50"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Đánh giá" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>


                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminReturnRequests"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_shipping_truck" app:tint="#F44336"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Khiếu nại" android:textStyle="bold" android:textSize="13sp"/>
                                </LinearLayout>
                                <TextView
                                    android:id="@+id/tvReturnBadge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:minWidth="18dp"
                                    android:minHeight="18dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_margin="8dp"
                                    android:background="@drawable/bg_circle_red_badge"
                                    android:gravity="center"
                                    android:textColor="#FFFFFF"
                                    android:textSize="9sp"
                                    android:textStyle="bold"
                                    android:padding="2dp"
                                    android:visibility="gone"/>
                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="16dp" android:background="#F0F0F0" />

                <LinearLayout
                    android:id="@+id/sectionFavorite"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_heart_filled" app:tint="#FF4081" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Sản phẩm yêu thích" android:textColor="#212121" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="#BDBDBD" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout
                    android:id="@+id/sectionChat"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/stat_notify_chat" app:tint="#29B6F6" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Chăm sóc khách hàng" android:textColor="#212121" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="#BDBDBD" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_lock_idle_lock" app:tint="#66BB6A" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Đổi mật khẩu" android:textColor="#212121" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="#BDBDBD" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_sky_blue_gradient"
                    android:text="ĐĂNG XUẤT"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <!-- SECTION: Gợi ý (Đã dời xuống DƯỚI CÙNG hoàn toàn, sau nút Logout) -->
                <LinearLayout
                    android:id="@+id/sectionSuggestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp"
                    android:paddingBottom="40dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:visibility="gone">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="16dp" android:text="CÓ THỂ BẠN SẼ THÍCH" android:textColor="#01579B" android:textStyle="bold" />
                    <com.example.buoi1.NonScrollGridView android:id="@+id/gvSuggestions" android:layout_width="match_parent" android:layout_height="wrap_content" android:numColumns="2" android:padding="8dp" />
