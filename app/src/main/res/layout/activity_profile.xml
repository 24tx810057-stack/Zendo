<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavProfile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Profile -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg"
                android:paddingHorizontal="16dp"
                android:paddingTop="60dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/btnSetting"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginEnd="20dp"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="#FFFFFF" />

                    <RelativeLayout
                        android:id="@+id/layoutCartProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageView
                            android:id="@+id/btnCartProfile"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_cart_logo"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:id="@+id/tvCartBadge"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_alignTop="@id/btnCartProfile"
                            android:layout_alignEnd="@id/btnCartProfile"
                            android:layout_marginTop="-6dp"
                            android:layout_marginEnd="-6dp"
                            android:background="@drawable/bg_circle_red_badge"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:visibility="gone" />
                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginBottom="50dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/ic_person"
                        android:scaleType="centerCrop"
                        android:background="#FFFFFF"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="#FFFFFF"
                        app:strokeWidth="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User Name"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvProfileRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_role_chip"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="2dp"
                            android:text="Thành viên"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- Main Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-30dp"
                android:background="@drawable/bg_white_top_round"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- SECTION: USER MENU (Orders) -->
                <LinearLayout
                    android:id="@+id/layoutUserMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="false">

                    <RelativeLayout
                        android:id="@+id/btnOrderHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:paddingBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đơn mua"
                            android:textStyle="bold"
                            android:textColor="#212121"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Xem lịch sử >"
                            android:textSize="12sp"
                            android:textColor="#757575"/>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="10dp"
                        android:weightSum="4"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <RelativeLayout android:id="@+id/btnStatusPending" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false">
                            <ImageView android:id="@+id/iv1" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_edit" app:tint="#424242"/>
                            <TextView android:id="@+id/badgePending" android:layout_width="14dp" android:layout_height="14dp" android:layout_alignEnd="@id/iv1" android:layout_alignTop="@id/iv1" android:layout_marginTop="-6dp" android:layout_marginEnd="-6dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="8sp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv1" android:text="Chờ xác nhận" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusPickup" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false">
                            <ImageView android:id="@+id/iv2" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_map" app:tint="#424242"/>
                            <TextView android:id="@+id/badgePickup" android:layout_width="14dp" android:layout_height="14dp" android:layout_alignEnd="@id/iv2" android:layout_alignTop="@id/iv2" android:layout_marginTop="-6dp" android:layout_marginEnd="-6dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="8sp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv2" android:text="Chờ lấy hàng" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusShipping" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false">
                            <ImageView android:id="@+id/iv3" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_email" app:tint="#424242"/>
                            <TextView android:id="@+id/badgeShipping" android:layout_width="14dp" android:layout_height="14dp" android:layout_alignEnd="@id/iv3" android:layout_alignTop="@id/iv3" android:layout_marginTop="-6dp" android:layout_marginEnd="-6dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="8sp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv3" android:text="Đang giao" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                        <RelativeLayout android:id="@+id/btnStatusReview" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:clipChildren="false">
                            <ImageView android:id="@+id/iv4" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/btn_star_big_on" app:tint="#424242"/>
                            <TextView android:id="@+id/badgeReview" android:layout_width="14dp" android:layout_height="14dp" android:layout_alignEnd="@id/iv4" android:layout_alignTop="@id/iv4" android:layout_marginTop="-6dp" android:layout_marginEnd="-6dp" android:background="@drawable/bg_circle_red_badge" android:gravity="center" android:textColor="#FFFFFF" android:textSize="8sp" android:visibility="gone"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/iv4" android:text="Đánh giá" android:textSize="10sp" android:layout_marginTop="6dp"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- SECTION: ADMIN SHOP CONTROL (Ô vuông 2x2) -->
                <LinearLayout
                    android:id="@+id/layoutAdminMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:clipChildren="false">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bảng điều khiển của Shop"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:alignmentMode="alignMargins"
                        android:clipChildren="false">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminOrders"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                    <ImageView android:id="@+id/ivAdminOrderIcon" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#01579B"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Đơn hàng" android:textStyle="bold" android:textSize="13sp"/>
                                </LinearLayout>
                                <TextView
                                    android:id="@+id/tvAdminOrderBadge"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_marginEnd="12dp"
                                    android:layout_marginTop="12dp"
                                    android:background="@drawable/bg_circle_red_badge"
                                    android:gravity="center"
                                    android:textColor="#FFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:visibility="gone"/>
                            </RelativeLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminProducts"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_input_add" app:tint="#FF9800"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Sản phẩm" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminVouchers"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/star_on" app:tint="#9C27B0"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Khuyến mãi" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAdminReviews"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
                                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/stat_notify_chat" app:tint="#4CAF50"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Đánh giá" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>
                </LinearLayout>

                <!-- Common items -->
                <LinearLayout
                    android:id="@+id/sectionChat"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/stat_notify_chat" app:tint="#29B6F6" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Chăm sóc khách hàng" android:textColor="#212121" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="#BDBDBD" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:id="@+id/ivLock" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_lock_idle_lock" app:tint="#66BB6A" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:text="Đổi mật khẩu" android:textColor="#212121" />
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_arrow_right" app:tint="#BDBDBD" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_sky_blue_gradient"
                    android:text="Đăng xuất"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Suggestions (Hidden for Admin) -->
            <LinearLayout
                android:id="@+id/sectionSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="16dp" android:text="CÓ THỂ BẠN SẼ THÍCH" android:textColor="#01579B" android:textStyle="bold" />
                <com.example.buoi1.NonScrollGridView android:id="@+id/gvSuggestions" android:layout_width="match_parent" android:layout_height="wrap_content" android:numColumns="2" android:padding="8dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>
