<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btnBackDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#2196F3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thiết lập hồ sơ"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnEditAccount"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="Sửa"
            android:textColor="#2196F3"
            android:textSize="14sp" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Avatar Section -->
            <RelativeLayout
                android:id="@+id/layoutChangeAvatar"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="#FFFFFF">

                <RelativeLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_centerInParent="true">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivDetailAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/ic_person"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="#29B6F6"
                        app:strokeWidth="2dp" />

                    <ImageView
                        android:id="@+id/ivCameraBadge"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:background="@drawable/circle_background_translucent"
                        android:padding="6dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:visibility="gone"
                        app:tint="#29B6F6" />
                </RelativeLayout>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:background="#EEEEEE" />

            <!-- BOX 1: Thông tin cơ bản -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Tên -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Tên" android:textColor="#212121" />
                    <EditText
                        android:id="@+id/etNicknameDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:enabled="false"
                        android:hint="Thiết lập ngay"
                        android:textColor="#212121"
                        android:textSize="14sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

                <!-- Bio -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Bio" android:textColor="#212121" />
                    <EditText
                        android:id="@+id/etBioDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:enabled="false"
                        android:hint="Thêm tiểu sử"
                        android:textColor="#212121"
                        android:textSize="14sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

                <!-- Giới tính -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Giới tính" android:textColor="#212121" />
                    <EditText
                        android:id="@+id/etGenderDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:enabled="false"
                        android:hint="Thiết lập ngay"
                        android:textColor="#212121"
                        android:textSize="14sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

                <!-- Ngày sinh -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Ngày sinh" android:textColor="#212121" />
                    <EditText
                        android:id="@+id/etBirthdateDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:enabled="false"
                        android:hint="Thiết lập ngay"
                        android:textColor="#212121"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:background="#EEEEEE" />

            <!-- BOX 2: Thông tin cá nhân -->
            <LinearLayout
                android:id="@+id/btnOpenPersonalInfo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thông tin cá nhân"
                    android:textColor="#212121"
                    android:textSize="14sp" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#BDBDBD" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:background="#EEEEEE" />

            <!-- BOX 3: Liên hệ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Điện thoại -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Số điện thoại" android:textColor="#212121" />
                    <EditText
                        android:id="@+id/etPhoneAccountDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:enabled="false"
                        android:hint="Thiết lập ngay"
                        android:inputType="phone"
                        android:textColor="#212121"
                        android:textSize="14sp" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Email" android:textColor="#212121" />
                    <TextView
                        android:id="@+id/tvEmailAccountDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#757575"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:background="#EEEEEE" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaveAccountDetail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_sky_blue_gradient"
                android:text="LƯU THAY ĐỔI"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
