<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <!-- Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbarCheckout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBackCheckout"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            app:tint="#2196F3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Xác nhận đơn hàng"
            android:textColor="#212121"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutBottomBarShadow"
        android:layout_below="@id/toolbarCheckout"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Khối 1: Địa chỉ & Sản phẩm -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:id="@+id/layoutAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivLoc"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_dialog_map"
                            app:tint="@color/blue_main" />

                        <TextView
                            android:id="@+id/tvLabelAdd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_toEndOf="@id/ivLoc"
                            android:text="Địa chỉ nhận hàng"
                            android:textColor="@color/blue_main"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnEditAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Thay đổi"
                            android:textColor="@color/blue_main"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCheckoutNamePhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvLabelAdd"
                            android:layout_marginStart="32dp"
                            android:layout_marginTop="8dp"
                            android:text="Họ tên | Số điện thoại"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCheckoutAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvCheckoutNamePhone"
                            android:layout_marginStart="32dp"
                            android:layout_marginTop="4dp"
                            android:text="Địa chỉ của bạn"
                            android:textColor="#757575"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnAddFirstAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvLabelAdd"
                            android:layout_marginTop="12dp"
                            android:text="THÊM ĐỊA CHỈ GIAO HÀNG"
                            android:visibility="gone"
                            android:backgroundTint="@color/blue_main"
                            android:textColor="#FFFFFF" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="16dp" android:background="#F0F0F0" />

                    <TextView
                        android:id="@+id/tvProductListHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thông tin sản phẩm"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutProductItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Khối 2: Vận chuyển & Voucher -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phương thức vận chuyển"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                            android:id="@+id/tvShippingBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_circle_red_badge"
                            android:backgroundTint="@color/blue_main"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="FREESHIP"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <LinearLayout
                        android:id="@+id/layoutShippingGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <!-- Hỏa tốc -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/layoutItemFast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_shipping_selector"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="12dp"
                            android:layout_marginBottom="8dp">
                            <RadioButton
                                android:id="@+id/rbFast"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="@color/blue_main"
                                android:text="Hỏa tốc"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:padding="0dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                android:clickable="false"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nhận hàng vào hôm nay hoặc ngày mai"
                                android:textColor="#757575"
                                android:textSize="11sp"
                                android:layout_marginStart="24dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/rbFast"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent">
                                <TextView
                                    android:id="@+id/tvFastOldPrice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="30.000đ"
                                    android:textColor="#9E9E9E"
                                    android:textSize="12sp"
                                    android:visibility="gone"/>
                                <TextView
                                    android:id="@+id/tvFastPrice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="30.000đ"
                                    android:textColor="@color/blue_main"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                            </LinearLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Tiêu chuẩn -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/layoutItemStandard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_shipping_selector"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="12dp">
                            <RadioButton
                                android:id="@+id/rbStandard"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="@color/blue_main"
                                android:text="Tiêu chuẩn"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:padding="0dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                android:clickable="false"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nhận hàng sau 2-3 ngày làm việc"
                                android:textColor="#757575"
                                android:textSize="11sp"
                                android:layout_marginStart="24dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/rbStandard"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent">
                                <TextView
                                    android:id="@+id/tvStandardOldPrice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="15.000đ"
                                    android:textColor="#9E9E9E"
                                    android:textSize="12sp"
                                    android:visibility="gone"/>
                                <TextView
                                    android:id="@+id/tvStandardPrice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="15.000đ"
                                    android:textColor="@color/blue_main"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                            </LinearLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="16dp" android:background="#F0F0F0" />

                    <!-- Voucher Section -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutVoucher"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:backgroundTint="#FAFAFA"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/ivVoucherIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_voucher_shopee"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:tint="@color/blue_main" />
                        <TextView
                            android:id="@+id/tvVoucherLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Zendo Voucher"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivVoucherIcon"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView
                            android:id="@+id/tvSelectedVoucher"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chọn mã giảm giá >"
                            android:textColor="@color/blue_main"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Khối 3: Phương thức thanh toán -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phương thức thanh toán"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- COD -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutPayCOD"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivCOD"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_save"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:tint="#FB8C00"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Thanh toán khi nhận hàng (COD)"
                            android:layout_marginStart="12dp"
                            android:textColor="#424242"
                            android:textSize="14sp"
                            app:layout_constraintStart_toEndOf="@id/ivCOD"
                            app:layout_constraintEnd_toStartOf="@+id/rbSelectCOD"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                        <RadioButton
                            android:id="@+id/rbSelectCOD"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_main"
                            android:checked="true"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:clickable="false"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Bank Transfer -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutPayBank"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivBank"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_dialog_info"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:tint="@color/blue_main"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Chuyển khoản ngân hàng"
                            android:layout_marginStart="12dp"
                            android:textColor="#424242"
                            android:textSize="14sp"
                            app:layout_constraintStart_toEndOf="@id/ivBank"
                            app:layout_constraintEnd_toStartOf="@+id/rbSelectBank"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                        <RadioButton
                            android:id="@+id/rbSelectBank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_main"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:clickable="false"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Bank Details -->
                    <LinearLayout
                        android:id="@+id/layoutBankDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F5F5F5"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thông tin chuyển khoản:"
                            android:textStyle="italic"
                            android:textSize="12sp"
                            android:layout_marginBottom="8dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số TK: 200100"
                                android:textColor="#212121"
                                android:textStyle="bold"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/btnCopySTK"
                                android:layout_marginEnd="8dp"/>
                            <ImageView
                                android:id="@+id/btnCopySTK"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_copy"
                                android:padding="4dp"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </RelativeLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chủ TK: NGUYEN QUOC BAO"
                            android:textColor="#212121"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngân hàng: VIB"
                            android:textColor="#212121"
                            android:layout_marginBottom="6dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:id="@+id/tvTransferNote"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Nội dung: Đang tải..."
                                android:textColor="#212121"
                                android:textStyle="bold"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/btnCopyNoiDung"
                                android:layout_marginEnd="8dp"/>
                            <ImageView
                                android:id="@+id/btnCopyNoiDung"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_copy"
                                android:padding="4dp"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </RelativeLayout>

                        <ImageView
                            android:id="@+id/ivBankQR"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:background="#FFFFFF"
                            android:padding="8dp"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="4dp"
                            android:text="Quét mã VietQR để thanh toán nhanh"
                            android:textColor="#757575"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- ZendoPay -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutPayZendo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivZendoPay"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_zendopay"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Ví ZendoPay"
                            android:layout_marginStart="12dp"
                            android:textColor="#424242"
                            android:textSize="14sp"
                            app:layout_constraintStart_toEndOf="@id/ivZendoPay"
                            app:layout_constraintEnd_toStartOf="@+id/rbSelectZendo"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                        <RadioButton
                            android:id="@+id/rbSelectZendo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_main"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:clickable="false"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Khối 4: Ghi chú & Tổng thanh toán -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ghi chú đơn hàng"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etOrderNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext"
                        android:hint="Lưu ý cho người bán..."
                        android:padding="12dp"
                        android:textSize="14sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="16dp" android:background="#F0F0F0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tổng tiền hàng" android:textColor="#757575" />
                        <TextView android:id="@+id/tvSummarySubtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textColor="#212121" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Phí vận chuyển" android:textColor="#757575" />
                        <TextView android:id="@+id/tvSummaryShipping" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textColor="#212121" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutSummaryDiscount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Voucher giảm giá" android:textColor="#757575" />
                        <TextView android:id="@+id/tvSummaryDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-0đ" android:textColor="#2E7D32" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#F0F0F0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tổng thanh toán" android:textColor="#212121" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvSummaryTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textColor="@color/blue_main" android:textSize="18sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Shadow cho Sticky Bottom Bar -->
    <View
        android:id="@+id/layoutBottomBarShadow"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_above="@+id/layoutBottomBar"
        android:background="@drawable/bg_top_shadow_gradient" />

    <!-- Sticky Bottom Bar -->
    <LinearLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bằng cách đặt hàng, bạn đồng ý với Điều khoản của Zendo"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tổng thanh toán" android:textColor="#757575" android:textSize="12sp" />
                <TextView android:id="@+id/tvSummaryTotalSticky" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textColor="@color/blue_main" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPlaceOrder"
                android:layout_width="160dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_sky_blue_gradient"
                android:text="ĐẶT HÀNG"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
