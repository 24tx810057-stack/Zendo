<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <RelativeLayout
        android:id="@+id/toolbarCheckout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="?attr/colorSurfaceVariant"
        android:elevation="0dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBackCheckout"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/blue_modern_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Xác nhận đơn hàng"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_alignParentBottom="true" android:background="?attr/colorOutline"/>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutBottomBarShadow"
        android:layout_below="@id/toolbarCheckout"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/colorSurfaceVariant"
                    android:padding="16dp">

                    <RelativeLayout
                        android:id="@+id/layoutAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/ivLoc"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_dialog_map"
                            app:tint="@color/blue_modern_primary" />

                        <TextView
                            android:id="@+id/tvLabelAdd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_toEndOf="@id/ivLoc"
                            android:text="Địa chỉ nhận hàng"
                            android:textColor="@color/blue_modern_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnEditAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Thay đổi"
                            android:textColor="@color/blue_modern_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCheckoutNamePhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvLabelAdd"
                            android:layout_marginStart="30dp"
                            android:layout_marginTop="8dp"
                            android:text="Họ tên | Số điện thoại"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCheckoutAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvCheckoutNamePhone"
                            android:layout_marginStart="30dp"
                            android:layout_marginTop="4dp"
                            android:text="Địa chỉ của bạn"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btnAddFirstAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvLabelAdd"
                            android:layout_marginTop="12dp"
                            android:text="THÊM ĐỊA CHỈ GIAO HÀNG"
                            android:visibility="gone"
                            app:backgroundTint="@color/blue_modern_primary"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="12dp"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurfaceVariant"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thông tin sản phẩm"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:id="@+id/layoutProductItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurfaceVariant"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phương thức vận chuyển"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                            android:id="@+id/tvShippingBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_freeship_badge"
                            android:drawableStart="@drawable/ic_shipping_truck"
                            android:drawablePadding="6dp"
                            android:drawableTint="#FFFFFF"
                            android:text="FREESHIP"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Hỏa tốc -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutItemFast"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp"
                        android:layout_marginBottom="12dp">
                        <RadioButton
                            android:id="@+id/rbFast"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_main"
                            android:text="Hỏa tốc"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:clickable="false"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhận hàng trong vòng 24h"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:layout_marginStart="24dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/rbFast"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:id="@+id/tvFastOldPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="30.000đ"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp"
                                android:layout_marginEnd="8dp"
                                android:visibility="gone"/>
                            <TextView
                                android:id="@+id/tvFastPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="30.000đ"
                                android:textColor="@color/blue_main"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:background="@android:color/transparent"/>
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Tiêu chuẩn -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutItemStandard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp">
                        <RadioButton
                            android:id="@+id/rbStandard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_main"
                            android:text="Tiêu chuẩn"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:clickable="false"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhận hàng sau 2-3 ngày làm việc"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:layout_marginStart="24dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/rbStandard"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:id="@+id/tvStandardOldPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15.000đ"
                                android:textColor="#9E9E9E"
                                android:textSize="12sp"
                                android:layout_marginEnd="8dp"
                                android:visibility="gone"/>
                            <TextView
                                android:id="@+id/tvStandardPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15.000đ"
                                android:textColor="@color/blue_main"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:background="@android:color/transparent"/>
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutVoucher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="16dp"
                    android:background="?attr/colorSurfaceVariant">
                    <ImageView
                        android:id="@+id/ivVoucherIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_voucher_shopee"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:tint="@color/blue_modern_primary" />
                    <TextView
                        android:id="@+id/tvVoucherLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Zendo Voucher"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivVoucherIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>
                    <TextView
                        android:id="@+id/tvSelectedVoucher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chọn mã giảm giá >"
                        android:textColor="@color/blue_modern_primary"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurfaceVariant"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phương thức thanh toán"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- COD -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutPayCOD"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:padding="14dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivCOD"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_save"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:tint="#FB8C00"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Thanh toán khi nhận hàng (COD)"
                            android:layout_marginStart="12dp"
                            android:textColor="#424242"
                            android:textSize="14sp"
                            app:layout_constraintStart_toEndOf="@id/ivCOD"
                            app:layout_constraintEnd_toStartOf="@+id/rbSelectCOD"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                        <RadioButton
                            android:id="@+id/rbSelectCOD"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_main"
                            android:checked="true"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:clickable="false"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Bank Transfer -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutPayBank"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:padding="14dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivBank"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_dialog_info"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:tint="@color/blue_main"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Chuyển khoản ngân hàng"
                            android:layout_marginStart="12dp"
                            android:textColor="#424242"
                            android:textSize="14sp"
                            app:layout_constraintStart_toEndOf="@id/ivBank"
                            app:layout_constraintEnd_toStartOf="@+id/rbSelectBank"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                        <RadioButton
                            android:id="@+id/rbSelectBank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_main"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:clickable="false"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Bank Details -->
                    <LinearLayout
                        android:id="@+id/layoutBankDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F5F5F5"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thông tin chuyển khoản:"
                            android:textStyle="italic"
                            android:textSize="12sp"
                            android:layout_marginBottom="8dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:id="@+id/tvBankSTK"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số TK: Đang tải..."
                                android:textColor="#212121"
                                android:textStyle="bold"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/btnCopySTK"
                                android:layout_marginEnd="8dp"/>
                            <ImageView
                                android:id="@+id/btnCopySTK"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_copy"
                                android:padding="4dp"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/tvBankOwner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chủ TK: Đang tải..."
                            android:textColor="#212121"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvBankName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngân hàng: Đang tải..."
                            android:textColor="#212121"
                            android:layout_marginBottom="6dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:id="@+id/tvTransferNote"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Nội dung: Đang tải..."
                                android:textColor="#212121"
                                android:textStyle="bold"
                                android:layout_alignParentStart="true"
                                android:layout_toStartOf="@+id/btnCopyNoiDung"
                                android:layout_marginEnd="8dp"/>
                            <ImageView
                                android:id="@+id/btnCopyNoiDung"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_copy"
                                android:padding="4dp"
                                android:background="?attr/selectableItemBackgroundBorderless"/>
                        </RelativeLayout>

                        <ImageView
                            android:id="@+id/ivBankQR"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:background="#FFFFFF"
                            android:padding="8dp"
                            android:scaleType="fitCenter" />
                    </LinearLayout>

                    <!-- ZendoPay -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutPayZendo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_shipping_selector"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivZendoPay"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_zendopay"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>

                        <TextView
                            android:id="@+id/tvZendoPayLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Ví ZendoPay"
                            android:layout_marginStart="12dp"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/ivZendoPay"
                            app:layout_constraintEnd_toStartOf="@+id/rbSelectZendo"
                            app:layout_constraintTop_toTopOf="@id/ivZendoPay"
                            app:layout_constraintBottom_toBottomOf="@id/ivZendoPay"/>

                        <TextView
                            android:id="@+id/tvWalletStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Chưa thiết lập ví"
                            android:textColor="@color/rose_600"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp"
                            android:visibility="gone"
                            app:layout_constraintStart_toStartOf="@id/tvZendoPayLabel"
                            app:layout_constraintEnd_toEndOf="@id/tvZendoPayLabel"
                            app:layout_constraintTop_toBottomOf="@id/tvZendoPayLabel"/>

                        <RadioButton
                            android:id="@+id/rbSelectZendo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/blue_modern_primary"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/ivZendoPay"
                            app:layout_constraintBottom_toBottomOf="@id/ivZendoPay"
                            android:clickable="false"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- ZendoPay Details -->
                    <LinearLayout
                        android:id="@+id/layoutZendoPayDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F0F7FF"
                        android:padding="12dp"
                        android:layout_marginTop="-4dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvCheckoutWalletBalance"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Số dư: 0đ"
                            android:textColor="@color/blue_modern_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnCheckoutDeposit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nạp tiền"
                            android:textColor="@color/blue_modern_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:background="@drawable/bg_deposit_button_outline"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurfaceVariant"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ghi chú đơn hàng"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/etOrderNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rounded_edittext"
                        android:hint="Lưu ý cho người bán..."
                        android:padding="12dp"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurfaceVariant"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chi tiết thanh toán"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tổng tiền hàng" android:textColor="#757575" />
                        <TextView android:id="@+id/tvSummarySubtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textColor="#212121" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Phí vận chuyển" android:textColor="#757575" />
                        <TextView android:id="@+id/tvSummaryShipping" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textColor="#212121" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutSummaryDiscount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Voucher giảm giá" android:textColor="#757575" />
                        <TextView android:id="@+id/tvSummaryDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-0đ" android:textColor="#2E7D32" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#F0F0F0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tổng thanh toán" android:textColor="#212121" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvSummaryTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textColor="@color/blue_main" android:textSize="18sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Shadow cho Sticky Bottom Bar -->
    <View
        android:id="@+id/layoutBottomBarShadow"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_above="@+id/layoutBottomBar"
        android:background="@drawable/bg_top_shadow_gradient" />

    <!-- Sticky Bottom Bar -->
    <LinearLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="?attr/colorSurfaceVariant"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tổng thanh toán" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="12sp" />
            <TextView android:id="@+id/tvSummaryTotalSticky" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textColor="@color/blue_modern_primary" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPlaceOrder"
            android:layout_width="160dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_sky_blue_gradient"
            android:text="ĐẶT HÀNG"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>
