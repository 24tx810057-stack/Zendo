<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/layoutActions"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvVoucherTitleItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên Voucher"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVoucherCodeItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="#E3F2FD"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Mã: CODE123"
                android:textColor="#01579B"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVoucherValueItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Giảm: 10%"
                android:textColor="#EE4D2D"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVoucherMinOrderItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đơn tối thiểu: 100.000đ"
                android:textColor="#757575"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:orientation="vertical">

            <Switch
                android:id="@+id/swVoucherActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#01579B"
                android:trackTint="#B3E5FC" />

            <ImageView
                android:id="@+id/btnDeleteVoucher"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#D32F2F" />
        </LinearLayout>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
