<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_modern"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Nạp tiền vào ví"
        android:textColor="@color/slate_900"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:hint="Nhập số tiền cần nạp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/blue_modern_primary"
        app:hintTextColor="@color/blue_modern_primary"
        app:prefixText="VNĐ "
        app:prefixTextColor="@color/slate_500">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDepositAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/slate_900"
            android:textSize="16sp"
            android:textStyle="bold" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn nguồn tiền"
        android:textColor="@color/slate_500"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <RadioGroup
        android:id="@+id/rgDepositSource"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rbSourceBank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tài khoản ngân hàng"
            android:textColor="?attr/colorOnSurface"
            android:buttonTint="@color/blue_modern_primary"
            android:paddingVertical="10dp"/>

        <RadioButton
            android:id="@+id/rbSourceMoMo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ví MoMo"
            android:textColor="?attr/colorOnSurface"
            android:buttonTint="@color/blue_modern_primary"
            android:paddingVertical="10dp"/>
    </RadioGroup>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConfirmDeposit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_sky_blue_gradient"
        android:text="XÁC NHẬN NẠP TIỀN"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCancelDeposit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:text="HỦY BỎ"
        android:textColor="@color/slate_500"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>