<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ZendoApps" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/blue_modern_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/blue_dark</item>

        <!-- Semantic Colors Light -->
        <item name="android:windowBackground">@color/slate_50</item>
        <item name="colorSurface">@color/slate_50</item>
        <item name="colorOnSurface">@color/slate_900</item>
        <item name="colorSurfaceVariant">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/slate_700</item>
        <item name="colorOutline">@color/slate_200</item>
        <item name="colorOutlineVariant">#F1F5F9</item>
        <item name="colorContainer">@color/white</item>
        <item name="colorOnContainer">@color/slate_900</item>

        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.ZendoApps" parent="Base.Theme.ZendoApps" />

    <style name="Theme.Zendo.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="CustomDialogTheme" parent="Theme.Material3.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <style name="BottomNavText">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>
</resources>
